---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Lili's Creations — Handcrafted Jewelry",
  description = "Handmade jewelry inspired by the textures, colors, and quiet beauty of the natural world. One-of-a-kind pieces crafted with natural stones, raw metals, and quiet intention."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ClientRouter />
    <!-- PayPal JS SDK — Replace YOUR_CLIENT_ID with your live PayPal Client ID -->
    <script is:inline src="https://www.paypal.com/sdk/js?client-id=ARMqV7_IvgaaxvMp-mWP_DpMmCizB62jEHwoTpAOn6PEn6BVq82F7PXSPyLgmj-BAZo2Qh5ZVTb9JU0N
&currency=USD&intent=capture" data-sdk-integration-source="button-factory" async></script>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll animation observer
      function initScrollAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.15 });

        document.querySelectorAll('.animate-on-scroll').forEach(el => {
          observer.observe(el);
        });
      }

      // Run on initial load and after view transitions
      initScrollAnimations();
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>
  </body>
</html>
