---
const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Browse the Collection', href: '/collection' },
  { label: 'Meet the Maker', href: '/about' },
  { label: 'Made Just for You', href: '/custom' },
  { label: 'Say Hello', href: '/contact' },
];

const currentPath = Astro.url.pathname;
---

<header class="header" id="site-header">
  <div class="header__inner container">
    <a href="/" class="header__logo" transition:name="logo">
      <span class="header__logo-name">Lili's Creations</span>
      <span class="header__logo-tagline">handcrafted with heart</span>
    </a>

    <nav class="header__nav" id="main-nav" aria-label="Main navigation">
      <ul class="header__nav-list">
        {navItems.map(item => (
          <li class="header__nav-item">
            <a
              href={item.href}
              class:list={['header__nav-link', { active: currentPath === item.href }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <button
      class="header__menu-toggle"
      id="menu-toggle"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="header__menu-bar"></span>
      <span class="header__menu-bar"></span>
      <span class="header__menu-bar"></span>
    </button>
  </div>

  <!-- Mobile menu -->
  <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav aria-label="Mobile navigation">
      <ul class="header__mobile-list">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class:list={['header__mobile-link', { active: currentPath === item.href }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(250, 248, 245, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: all var(--transition-base);
  }

  .header--scrolled {
    box-shadow: 0 2px 20px rgba(61, 54, 48, 0.06);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
  }

  .header__logo {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    line-height: 1.2;
  }

  .header__logo-name {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 500;
    color: var(--color-text);
    letter-spacing: 0.05em;
  }

  .header__logo-tagline {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-primary);
    letter-spacing: 0.1em;
  }

  .header__nav-list {
    display: flex;
    gap: var(--space-md);
    align-items: center;
  }

  .header__nav-link {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-light);
    text-decoration: none;
    padding: 0.4rem 0;
    position: relative;
    transition: color var(--transition-base);
  }

  .header__nav-link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--color-primary);
    transition: all var(--transition-base);
    transform: translateX(-50%);
  }

  .header__nav-link:hover,
  .header__nav-link.active {
    color: var(--color-primary);
  }

  .header__nav-link:hover::after,
  .header__nav-link.active::after {
    width: 100%;
  }

  /* Hamburger */
  .header__menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    z-index: 1001;
  }

  .header__menu-bar {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--color-text);
    transition: all var(--transition-base);
    transform-origin: center;
  }

  .header__menu-toggle.open .header__menu-bar:nth-child(1) {
    transform: rotate(45deg) translate(5px, 4px);
  }

  .header__menu-toggle.open .header__menu-bar:nth-child(2) {
    opacity: 0;
  }

  .header__menu-toggle.open .header__menu-bar:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -4px);
  }

  /* Mobile Menu */
  .header__mobile-menu {
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-slow);
    z-index: 999;
  }

  .header__mobile-menu.open {
    opacity: 1;
    visibility: visible;
  }

  .header__mobile-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-lg);
  }

  .header__mobile-link {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    font-weight: 400;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color var(--transition-base);
    opacity: 0;
    transform: translateY(20px);
    transition: all var(--transition-slow);
  }

  .header__mobile-menu.open .header__mobile-link {
    opacity: 1;
    transform: translateY(0);
  }

  .header__mobile-menu.open li:nth-child(1) .header__mobile-link { transition-delay: 0.1s; }
  .header__mobile-menu.open li:nth-child(2) .header__mobile-link { transition-delay: 0.15s; }
  .header__mobile-menu.open li:nth-child(3) .header__mobile-link { transition-delay: 0.2s; }
  .header__mobile-menu.open li:nth-child(4) .header__mobile-link { transition-delay: 0.25s; }
  .header__mobile-menu.open li:nth-child(5) .header__mobile-link { transition-delay: 0.3s; }

  .header__mobile-link:hover,
  .header__mobile-link.active {
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .header__nav { display: none; }
    .header__menu-toggle { display: flex; }
  }
</style>

<script>
  function initHeader() {
    const header = document.getElementById('site-header');
    const toggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    // Scroll effect
    let lastScroll = 0;
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        header?.classList.add('header--scrolled');
      } else {
        header?.classList.remove('header--scrolled');
      }
      lastScroll = window.scrollY;
    });

    // Mobile menu toggle
    toggle?.addEventListener('click', () => {
      const isOpen = toggle.classList.contains('open');
      toggle.classList.toggle('open');
      mobileMenu?.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(!isOpen));
      mobileMenu?.setAttribute('aria-hidden', String(isOpen));
      document.body.style.overflow = isOpen ? '' : 'hidden';
    });

    // Close mobile menu on link click
    mobileMenu?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        toggle?.classList.remove('open');
        mobileMenu.classList.remove('open');
        document.body.style.overflow = '';
      });
    });
  }

  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
